{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ryze AI",
  "colors": {
    "primary": "#242424",
    "light": "#F5F5F5",
    "dark": "#1A1A1A"
  },
  "fonts": {
    "family": "Plus Jakarta Sans"
  },
  "favicon": "/favicon.ico",
  "seo": {
    "metatags": {
      "description": "Help center for Ryze AI — the AI ad manager for Meta, Google, TikTok, and more.",
      "og:type": "website",
      "og:site_name": "Ryze AI",
      "og:title": "Ryze AI Help Center",
      "og:description": "Connect your ad accounts, set up Ryze in Claude, and manage billing — all in one place.",
      "og:image": "https://docs.get-ryze.ai/images/og.png",
      "twitter:card": "summary_large_image",
      "twitter:title": "Ryze AI Help Center",
      "twitter:description": "Connect your ad accounts, set up Ryze in Claude, and manage billing — all in one place.",
      "twitter:image": "https://docs.get-ryze.ai/images/og.png"
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "search": {
    "prompt": "Search Ryze docs..."
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "overview",
          "what-ryze-does"
        ]
      },
      {
        "group": "Connect",
        "pages": [
          "connect/ad-accounts",
          "connect/claude",
          "connect/faq"
        ]
      },
      {
        "group": "Billing",
        "pages": [
          "billing/overview",
          "billing/faq"
        ]
      },
      {
        "group": "Security",
        "pages": [
          "security/overview",
          "security/data-storage",
          "security/data-processing"
        ]
      },
      {
        "group": "Help",
        "pages": [
          "help/contact"
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://status.get-ryze.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.get-ryze.ai/integrations"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {}
  }
}